{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky install",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate:product": "npx prisma generate --schema=apps/api-product/prisma/schema.prisma",
    "db:generate:cart": "npx prisma generate --schema=apps/api-cart/prisma/schema.prisma",
    "db:generate:order": "npx prisma generate --schema=apps/api-order/prisma/schema.prisma",
    "db:generate": "npm run db:generate:product && npm run db:generate:cart && npm run db:generate:order",
    "db:migrate:product": "npx prisma migrate dev --schema=apps/api-product/prisma/schema.prisma",
    "db:migrate:cart": "npx prisma migrate dev --schema=apps/api-cart/prisma/schema.prisma",
    "db:migrate:order": "npx prisma migrate dev --schema=apps/api-order/prisma/schema.prisma",
    "db:migrate": "npm run db:migrate:product && npm run db:migrate:cart && npm run db:migrate:order",
    "db:seed:product": "npx tsx apps/api-product/prisma/seed.ts",
    "db:seed:cart": "npx tsx apps/api-cart/prisma/seed.ts",
    "db:seed:order": "npx tsx apps/api-order/prisma/seed.ts",
    "db:seed": "npm run db:seed:product && npm run db:seed:cart && npm run db:seed:order",
    "db:setup": "npm run db:up && npm run db:generate && npm run db:migrate && npm run db:seed"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/devkit": "22.5.1",
    "@nx/jest": "22.5.1",
    "@nx/js": "22.5.3",
    "@nx/next": "^22.5.1",
    "@nx/node": "22.5.3",
    "@nx/playwright": "22.5.1",
    "@nx/web": "22.5.3",
    "@nx/webpack": "22.5.3",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@swc/jest": "^0.2.29",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/graphql": "^14.2.3",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "jest-environment-node": "^30.0.0",
    "nx": "22.5.1",
    "postcss": "^8.5.6",
    "prettier": "^2.6.2",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@apollo/gateway": "^2.13.1",
    "@apollo/server": "^5.4.0",
    "@apollo/subgraph": "^2.13.1",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nx/nest": "^22.5.3",
    "@prisma/client": "^7.4.2",
    "apollo-server": "^3.13.0",
    "axios": "^1.6.0",
    "dataloader": "^2.2.3",
    "graphql": "^16.13.0",
    "graphql-query-complexity": "^0.12.0",
    "next": "~16.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "npm": {
    "strictPeerDependencies": false
  }
}
