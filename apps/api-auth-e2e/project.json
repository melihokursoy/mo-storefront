{
  "name": "api-auth-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api-auth-e2e/src",
  "prefix": "api-auth-e2e",
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/api-auth-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        {
          "projects": "api-auth",
          "target": "serve"
        },
        {
          "projects": "api-user",
          "target": "serve"
        }
      ]
    }
  },
  "tags": []
}
